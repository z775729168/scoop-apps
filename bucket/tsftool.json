{
    "version": "4.4.4",
    "description": "输入法设置工具",
    "homepage": "https://www.mympc.org/default/tsftool.html",
    "license": "Freeware",
    "url": "https://123.zhutix.com/2024/ruanjian/UltraUXThemePatcher_4.4.4.exe",
    "hash": "9945195d54509ca4e8a41e468851137a56f711163d4fcbe4a8692ed24023a739",
    "architecture": {
        "64bit": {
            "extract_dir": "Win64"
        },
        "32bit": {
            "extract_dir": "Win32"
        }
    },
    "shortcuts": [
        [
            "TSFTool.exe",
            "TSFTool"
        ]
    ],
    "checkver": {
        "script": [
            "$url = \"https://mympc.org/default/tsftool.html\"",
            "$html = Invoke-WebRequest -Uri $url -UseBasicParsing",
            "if ($html.Content -match 'TSFTool V([\\d.]+)') {",
            "    $version = $matches[1]",
            "} else {",
            "    Write-Host \"Version not found\"",
            "    return",
            "}",
            "if ($html.Content -match 'https://www\\.mympc\\.org/usr/uploads/\\d{4}/\\d{2}/tsftool\\.rar') {",
            "    $url = $matches[0]",
            "} else {",
            "    Write-Host \"Download URL not found\"",
            "    return",
            "}",
            "return \"$version=====$url\""
        ],
        "regex": "(.*)=====(?<url>.*)"
    },
    "autoupdate": {
        "url": "$matchUrl"
    }
}
