    "checkver": {
        "script": [
            "$url = \"https://mympc.org/default/tsftool.html\"",
            "$html = Invoke-WebRequest -Uri $url -UseBasicParsing",
            "if ($html.Content -match 'TSFTool V([\\d.]+)') {",
