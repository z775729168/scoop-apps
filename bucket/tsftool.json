{
    "version": "5.30.1.3586",
    "description": "输入法设置工具",
    "homepage": "https://www.mympc.org/default/tsftool.html",
    "license": "Freeware",
    "url": "http://a11.gdl.netease.com/MuMu-setup-V5.30.1.3586-0523181240.exe",
    "hash": "8c4a6e93e613f56917eb988c82ebfff33dd2e9cada9ba05193ad77963371a1fd",
    "architecture": {
        "64bit": {
            "extract_dir": "Win64"
        },
        "32bit": {
            "extract_dir": "Win32"
        }
    },
    "shortcuts": [
        [
            "TSFTool.exe",
            "TSFTool"
        ]
    ],
    "checkver": {
        "script": [
            "$url = \"https://mympc.org/default/tsftool.html\"",
            "$html = Invoke-WebRequest -Uri $url -UseBasicParsing",
            "if ($html.Content -match 'TSFTool V([\\d.]+)') {",
            "    $version = $matches[1]",
            "} else {",
            "    Write-Host \"Version not found\"",
            "    return",
            "}",
            "if ($html.Content -match 'https://www\\.mympc\\.org/usr/uploads/\\d{4}/\\d{2}/tsftool\\.rar') {",
            "    $url = $matches[0]",
            "} else {",
            "    Write-Host \"Download URL not found\"",
            "    return",
            "}",
            "return \"$version=====$url\""
        ],
        "regex": "(.*)=====(?<url>.*)"
    },
    "autoupdate": {
        "url": "$matchUrl"
    }
}
