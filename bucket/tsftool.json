{
    "version": "3.2.1.0",
    "description": "输入法设置工具",
    "homepage": "https://www.mympc.org/default/tsftool.html",
    "license": "Freeware",
    "url": "https://app.123957.com/pc-pro/windows/321/123pan_3.2.1.exe",
    "hash": "7ae74899321d32b4c169c8e4111fa2b95d0681c0f33662089628837db38a1516",
    "architecture": {
        "64bit": {
            "extract_dir": "Win64"
        },
        "32bit": {
            "extract_dir": "Win32"
        }
    },
    "shortcuts": [
        [
            "TSFTool.exe",
            "TSFTool"
        ]
    ],
    "checkver": {
        "script": [
            "$url = \"https://mympc.org/default/tsftool.html\"",
            "$html = Invoke-WebRequest -Uri $url -UseBasicParsing",
            "if ($html.Content -match 'TSFTool V([\\d.]+)') {",
            "    $version = $matches[1]",
            "} else {",
            "    Write-Host \"Version not found\"",
            "    return",
            "}",
            "if ($html.Content -match 'https://www\\.mympc\\.org/usr/uploads/\\d{4}/\\d{2}/tsftool\\.rar') {",
            "    $url = $matches[0]",
            "} else {",
            "    Write-Host \"Download URL not found\"",
            "    return",
            "}",
            "return \"$version=====$url\""
        ],
        "regex": "(.*)=====(?<url>.*)"
    },
    "autoupdate": {
        "url": "$matchUrl"
    }
}
