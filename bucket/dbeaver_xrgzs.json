{
    "version": "26.1.3",
    "description": "Free universal database tool and SQL client",
    "homepage": "https://dbeaver.io",
    "license": "Apache-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/dbeaver/dbeaver/releases/download/26.1.3/dbeaver-ce-26.1.3-windows-x86_64.zip",
            "hash": "084ab253e18f19fcd06e7bc0824923e778926cce0f96c3cf4b02636fab1609da"
        },
        "arm64": {
            "url": "https://github.com/dbeaver/dbeaver/releases/download/26.1.3/dbeaver-ce-26.1.3-windows-aarch64.zip",
            "hash": "7d85f6f50176a14f43ffc4827710c8d7d38d4a32260d27b91f43860410511571"
        }
    },
    "extract_dir": "dbeaver",
    "bin": [
        "dbeaver.exe",
        "dbeaverc.exe"
    ],
    "shortcuts": [
        [
            "dbeaver.exe",
            "DBeaver"
        ]
    ],
    "installer": {
        "script": [
            "Remove-Item \"$dir\\`$*\" -Recurse -Force",
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "New-PersistDirectory \"$env:APPDATA\\DBeaverData\" \"$persist_dir\\AppData\" -Migrate"
        ]
    },
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:APPDATA\\DBeaverData\""
    ],
    "checkver": {
        "github": "https://github.com/dbeaver/dbeaver"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/dbeaver/dbeaver/releases/download/$version/dbeaver-ce-$version-windows-x86_64.zip"
            },
            "arm64": {
                "url": "https://github.com/dbeaver/dbeaver/releases/download/$version/dbeaver-ce-$version-windows-aarch64.zip"
            }
        }
    }
}
