{
    "version": "26.1.2",
    "description": "Free universal database tool and SQL client",
    "homepage": "https://dbeaver.io",
    "license": "Apache-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/dbeaver/dbeaver/releases/download/26.1.2/dbeaver-ce-26.1.2-windows-x86_64.zip",
            "hash": "9b30e00bf73b694411029fef727beec8316d6a2be246f24e944a6cdf97131b7c"
        },
        "arm64": {
            "url": "https://github.com/dbeaver/dbeaver/releases/download/26.1.2/dbeaver-ce-26.1.2-windows-aarch64.zip",
            "hash": "3f40d2fe99bc9020e82c18d25757bbccbfbdafc5ffe744c585d0c586c5e6bdf0"
        }
    },
    "extract_dir": "dbeaver",
    "bin": [
        "dbeaver.exe",
        "dbeaverc.exe"
    ],
    "shortcuts": [
        [
            "dbeaver.exe",
            "DBeaver"
        ]
    ],
    "installer": {
        "script": [
            "Remove-Item \"$dir\\`$*\" -Recurse -Force",
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "New-PersistDirectory \"$env:APPDATA\\DBeaverData\" \"$persist_dir\\AppData\" -Migrate"
        ]
    },
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:APPDATA\\DBeaverData\""
    ],
    "checkver": {
        "github": "https://github.com/dbeaver/dbeaver"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/dbeaver/dbeaver/releases/download/$version/dbeaver-ce-$version-windows-x86_64.zip"
            },
            "arm64": {
                "url": "https://github.com/dbeaver/dbeaver/releases/download/$version/dbeaver-ce-$version-windows-aarch64.zip"
            }
        }
    }
}
