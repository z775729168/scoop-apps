{
    "version": "3.12",
    "homepage": "https://www.nljs.site/nsis-zh-cn.html",
    "description": "(sudo) 安装包制作工具 NSIS 汉化增强版。此次汉化版主要汉化了NSIS自带程序的界面文字，整合了一些插件的翻译，并对Modern UI（1.81&2.1）进行了翻译跟进，NSIS帮助文件也进行了更新，还集成了Notepad2编辑器，另外增加以了一些插件，并整合了一个NSIS插件教程合集，在不追求大而全的情况下整合了最常用的插件",
    "license": "Zlib",
    "url": "https://api.xrgzs.top/sdlp/lanzou/?url=https://www.lanzoui.com/i7USZ3rst8xe&type=down#/installer.exe",
    "hash": "f5c54138119e8a037b298f36f13879dbce724f0e36df48cc78f33764a6b8baa2",
    "bin": [
        "bin\\makensis.exe",
        "makensisw.exe"
    ],
    "shortcuts": [
        [
            "makensisw.exe",
            "NSIS NanLon"
        ]
    ],
    "env_set": {
        "NSISDIR": "$dir"
    },
    "installer": {
        "script": [
            "Invoke-ExternalCommand \"$dir\\installer.exe\" -ArgumentList @('/S', \"/D=$dir\") -Quiet",
            "Remove-Item \"$dir\\installer.exe\" -Force -ErrorAction SilentlyContinue | Out-Null"
        ]
    },
    "pre_uninstall": [
        "Invoke-ExternalCommand \"$dir\\uninstall.exe\" -ArgumentList '/S' -Quiet",
        "Start-Sleep -Seconds 10",
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App"
    ],
    "checkver": {
        "script": [
            ". \"$pwd\\bin\\utils.ps1\"",
            "$f = Get-LanzouList \"https://nljs.lanzouw.com/b0d0zx1ve\" | Where-Object { $_.name_all -like \"nsis-chs-plus-*-setup.exe\" } | Select-Object -First 1",
            "$f.name_all + '=====' + $f.id"
        ],
        "regex": "nsis-chs-plus-(.*)-setup.exe=====(?<sharekey>.*)"
    },
    "autoupdate": {
        "url": "https://api.xrgzs.top/sdlp/lanzou/?url=https://www.lanzoui.com/$matchSharekey&type=down#/installer.exe"
    }
