    "pre_install": [
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "New-PersistDirectory \"$env:LOCALAPPDATA\\com.astrbot.desktop.tauri\" \"$persist_dir\\LocalAppData\" -Migrate"
