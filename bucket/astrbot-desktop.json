        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:LOCALAPPDATA\\com.astrbot.desktop.tauri\""
    ],
    "checkver": {
        "github": "https://github.com/AstrBotDevs/AstrBot-desktop"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/AstrBotDevs/AstrBot-desktop/releases/download/v$version/AstrBot_$version_windows_amd64_setup.exe#/dl.7z"
            },
