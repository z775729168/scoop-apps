{
    "version": "0.9.0",
    "description": "A desktop application for OpenList",
    "homepage": "https://oplist.org/",
    "license": "GPL-3.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://github.com/OpenListTeam/OpenList-Desktop/releases/download/v0.9.0/OpenList-Desktop_0.9.0_x64-setup.exe#/dl.7z",
            "hash": "e25e5c93d560471a9b2aeaea951a4a6b5a927e2ae03a1c90e2b9ee9c26a03235"
        },
        "arm64": {
            "url": "https://github.com/OpenListTeam/OpenList-Desktop/releases/download/v0.9.0/OpenList-Desktop_0.9.0_arm64-setup.exe#/dl.7z",
            "hash": "870bb765b44db294f81e4da4c31236280a693be89d349f957eefac8069d32304"
        }
    },
    "shortcuts": [
        [
            "openlist-desktop.exe",
            "OpenList Desktop"
        ]
    ],
    "pre_install": [
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "New-PersistDirectory \"$env:APPDATA\\OpenList Desktop\" \"$persist_dir\\AppData\" -Migrate",
        "if (!(Test-Path \"$persist_dir\\AppData\\settings.json\") -or !(Get-Item \"$persist_dir\\AppData\\settings.json\").Length) {",
        "    New-Item \"$persist_dir\\AppData\\settings.json\" -ItemType File -Force -ErrorAction SilentlyContinue | Out-Null",
        "    Set-Content -Path \"$persist_dir\\AppData\\settings.json\" -Value '{\"app\":{\"auto_update_enabled\":false}}'",
        "}"
    ],
    "post_install": "Remove-Item \"$dir\\`$*\", \"$dir\\Uninstall.exe\" -Force -Recurse -ErrorAction Ignore | Out-Null",
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:APPDATA\\OpenList Desktop\""
    ],
    "checkver": {
        "github": "https://github.com/OpenListTeam/OpenList-Desktop"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/OpenListTeam/OpenList-Desktop/releases/download/v$version/OpenList-Desktop_$version_x64-setup.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/OpenListTeam/OpenList-Desktop/releases/download/v$version/OpenList-Desktop_$version_arm64-setup.exe#/dl.7z"
            }
        }
    }
}
