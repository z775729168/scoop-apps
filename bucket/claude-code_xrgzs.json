{
    "version": "2.1.215",
    "description": "An agentic coding tool built by Anthropic that lives in your terminal, understands your codebase, and helps you code faster by executing routine tasks, explaining complex code, and handling git workflows.",
    "homepage": "https://claude.com/product/claude-code",
    "license": {
        "identifier": "Proprietary",
        "url": "https://www.anthropic.com/legal/consumer-terms"
    },
    "notes": [
        "Claude Code nonessential network traffic is disabled by default.",
        "It's recommended to use `extras/cc-switch` to configure third-party API subscriptions."
    ],
    "suggest": {
        "cc-switch": "extras/cc-switch"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/anthropics/claude-code/releases/download/v2.1.215/claude-win32-x64.zip",
            "hash": "afc538e31529dde5b4a4c4a03a90b877c8827d326651c01d0ba2b3f6a161fb8d"
        },
        "arm64": {
            "url": "https://github.com/anthropics/claude-code/releases/download/v2.1.215/claude-win32-arm64.zip",
            "hash": "d3dbd16dc9a9a5c05b8a40342cb4e2ca18992f61986bd94f7a5e4a3090444957"
        }
    },
    "bin": "claude.exe",
    "installer": {
        "script": [
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "New-PersistDirectory \"$env:USERPROFILE\\.claude\" \"$persist_dir\\.claude\" -Migrate",
            "if (!(Test-Path \"$persist_dir\\.claude\\settings.json\") -or !(Get-Item \"$persist_dir\\.claude\\settings.json\").Length) {",
            "    New-Item \"$persist_dir\\.claude\\settings.json\" -ItemType File -Force -ErrorAction SilentlyContinue | Out-Null",
            "    Set-Content -Path \"$persist_dir\\.claude\\settings.json\" -Value '{\"env\":{\"CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC\":\"1\",\"CLAUDE_CODE_USE_POWERSHELL_TOOL\":\"1\"},\"skipWebFetchPreflight\":true}' -Encoding Ascii",
            "}"
        ]
    },
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:USERPROFILE\\.claude\""
    ],
    "checkver": {
        "github": "https://github.com/anthropics/claude-code"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/anthropics/claude-code/releases/download/v$version/claude-win32-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/anthropics/claude-code/releases/download/v$version/claude-win32-arm64.zip"
            }
        }
    }
}
