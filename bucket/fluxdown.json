            "hash": "8d5e966d3f42d43e69487275bc384e1d7db1f2883eea36c4308e0e9e4faab891"
        },
        "arm64": {
            "url": "https://fluxdown.zerx.dev/api/download/FluxDown-0.1.58-windows-arm64-portable.zip",
            "hash": "a49e0a91c583d2763e33546b1e589f61c403585a6a895123e1521e23b0bc0984"
        }
    },
    "bin": "flux_down.exe",
    "shortcuts": [
        [
            "flux_down.exe",
            "FluxDown"
        ]
    ],
    "installer": {
        "script": [
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "New-PersistDirectory \"$env:APPDATA\\FluxDown\" \"$persist_dir\\AppData\" -Migrate",
            "# The portable FluxDown saves SQLite database in program directory.",
            "# To avoid data loss, we turn it into non-portable.",
            "Remove-Item \"$dir\\portable\" -Force",
            "New-PersistDirectory \"$env:LOCALAPPDATA\\FluxDown\" \"$persist_dir\\LocalAppData\" -Migrate"
        ]
    },
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:APPDATA\\FluxDown\"",
        "Remove-Junction \"$env:LOCALAPPDATA\\FluxDown\""
    ],
    "checkver": {
        "url": "https://fluxdown.zerx.dev/api/release",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://fluxdown.zerx.dev/api/download/FluxDown-$version-windows-x64-portable.zip"
            },
            "arm64": {
                "url": "https://fluxdown.zerx.dev/api/download/FluxDown-$version-windows-arm64-portable.zip"
