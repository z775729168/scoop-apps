{
    "version": "0.7.8-beta",
    "description": "SnowShot 是一款功能强大的截图工具，集成了文字识别、翻译和 AI 对话等功能",
    "homepage": "https://github.com/mg-chao/snow-shot",
    "license": "Apache-2.0|GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/mg-chao/snow-shot/releases/download/v0.7.8-beta/Snow.Shot_0.7.8-beta_windows-x64-portable.zip",
            "extract_dir": "Snow Shot_0.7.8-beta_windows-x64-portable",
            "hash": "f3747eb9cd256bb7f35c43c2218a83090af58830fe482d2975cea154f8de80ed"
        }
    },
    "shortcuts": [
        [
            "snowshot.exe",
            "Snow Shot"
        ]
    ],
    "installer": {
        "script": [
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "New-PersistDirectory \"$env:LOCALAPPDATA\\com.chao.snowshot\" \"$persist_dir\\LocalAppData\" -Migrate",
            "Remove-Item \"$dir\\`$*\", \"$dir\\Uninstall*\" -Force -Recurse"
        ]
    },
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:LOCALAPPDATA\\com.chao.snowshot\""
    ],
    "persist": [
        "configs",
        "plugins",
        "stores",
        "captureHistoryImages"
    ],
    "checkver": {
        "url": "https://github.com/mg-chao/snow-shot/releases/latest/download/latest.json",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/mg-chao/snow-shot/releases/download/v$version/Snow.Shot_$version_windows-x64-portable.zip",
                "extract_dir": "Snow Shot_$version_windows-x64-portable"
            }
        }
    }
}
