{
    "version": "1.7.22",
    "description": "🍒 Cherry Studio is a desktop client that supports for multiple LLM providers.",
    "homepage": "https://cherry-ai.com/",
    "license": {
        "identifier": "Apache-2.0",
        "url": "https://github.com/CherryHQ/cherry-studio/blob/main/LICENSE"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v1.7.22/Cherry-Studio-1.7.22-x64-setup.exe#/dl.7z",
            "hash": "sha512:a22582bc9136557aa5929cc44456892082bc66b31d8f831d6e884a86465bc5bb87281bf5f324e03cc53300da19eaa81a3eef53301642e6ba8adb7ea584e34838",
            "pre_install": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\""
        },
        "arm64": {
            "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v1.7.22/Cherry-Studio-1.7.22-arm64-setup.exe#/dl.7z",
            "hash": "59322588e8ca8c0005420a09fbeb25da77fa211ee7eeb0eb8a87ee59bc3ab300",
            "pre_install": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-arm64.7z\" \"$dir\""
        }
    },
    "shortcuts": [
        [
            "Cherry Studio.exe",
            "Cherry Studio"
        ]
    ],
    "installer": {
        "script": [
            "Remove-Item \"$dir\\`$*\" -Force -Recurse",
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "New-PersistDirectory \"$env:APPDATA\\CherryStudio\" \"$persist_dir\\AppData\" -Migrate"
        ]
    },
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:APPDATA\\CherryStudio\""
    ],
    "checkver": {
        "github": "https://github.com/CherryHQ/cherry-studio"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v$version/Cherry-Studio-$version-x64-setup.exe#/dl.7z",
                "hash": {
                    "mode": "extract",
                    "url": "$baseurl/latest.yml",
                    "regex": "sha512:\\s+$base64"
                }
            },
            "arm64": {
                "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v$version/Cherry-Studio-$version-arm64-setup.exe#/dl.7z",
                "hash": {
                    "mode": "download"
                }
            }
        }
    }
}
