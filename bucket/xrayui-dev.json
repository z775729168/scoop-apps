{
    "version": "1.17",
    "description": "Lightweight native Windows GUI client for Xray core, built with WinUI 3",
    "homepage": "https://github.com/PhoenixNil/XrayUI-dev",
    "license": "Apache-2.0",
    "suggest": {
        ".NET Desktop Runtime": "windowsdesktop-runtime"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/PhoenixNil/XrayUI-dev/releases/download/1.17/XrayUI-win-x64.zip",
            "hash": "3a982ac22831aecfc6ea2e63723ed1d2bb844e9d640af6f5a3d0ee6e5dff4dc9"
        },
        "arm64": {
            "url": "https://github.com/PhoenixNil/XrayUI-dev/releases/download/1.17/XrayUI-win-arm64.zip",
            "hash": "1f2732cdc85d4d9f40e143897371089ee466babf556e5339ff32d67cd3ab3895"
        }
    },
    "shortcuts": [
        [
            "XrayUI.exe",
            "XrayUI"
        ]
    ],
    "persist": "Data",
    "installer": {
        "script": [
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "New-PersistDirectory \"$env:LOCALAPPDATA\\XrayUI\" \"$persist_dir\\Data\" -Migrate"
        ]
    },
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:LOCALAPPDATA\\XrayUI\""
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/PhoenixNil/XrayUI-dev/releases/download/$version/XrayUI-win-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/PhoenixNil/XrayUI-dev/releases/download/$version/XrayUI-win-arm64.zip"
            }
        }
    }
}
