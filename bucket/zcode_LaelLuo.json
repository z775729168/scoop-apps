{
    "version": "3.3.3",
    "description": "智谱 ZCode - GLM 官方适配的 AI 编程开发工具（IDE）。",
    "homepage": "https://zcode.z.ai/cn",
    "license": "Proprietary",
    "architecture": {
        "64bit": {
            "url": "https://cdn-zcode.z.ai/zcode/electron/releases/3.3.3/ZCode-3.3.3-win-x64.exe#/dl.7z",
            "hash": "9799670b6cfb7b1e7ae87af3ebec6a440360fe39749e7cfd9274656f042a541d"
        }
    },
    "pre_install": [
        "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
        "Remove-Item \"$dir\\`$*\", \"$dir\\Uninstall*\" -Recurse -ErrorAction SilentlyContinue"
    ],
    "shortcuts": [
        [
            "ZCode.exe",
            "ZCode"
        ]
    ],
    "portableProfile": {
        "mappings": [
            {
                "label": "home",
                "source": "UserProfile/.zcode",
                "target": "$persist_dir/home",
                "strategy": "symlink",
                "ensureTarget": true
            },
            {
                "label": "roaming",
                "source": "AppData/ZCode",
                "target": "$persist_dir/roaming",
                "strategy": "symlink",
                "ensureTarget": true
            },
            {
                "label": "updater",
                "source": "LocalAppData/@zcodedesktop-updater",
                "target": "$persist_dir/local/zcode-updater",
                "strategy": "symlink",
                "ensureTarget": true,
                "targetType": "file"
            }
        ],
        "options": {
            "log": true
        }
    },
    "checkver": {
        "url": "https://zcode.z.ai/cn/changelog",
        "regex": "font-mono text-sm\">([\\d.]+)</span>"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://cdn-zcode.z.ai/zcode/electron/releases/$version/ZCode-$version-win-x64.exe#/dl.7z"
            }
        }
    }
}
