{
    "homepage": "https://music.163.com/",
    "description": "The official NetEase Cloud Music client.",
    "version": "3.1.29.205104",
    "license": {
        "identifier": "EULA",
        "url": "https://music.163.com/html/web2/service.html"
    },
    "architecture": {
        "64bit": {
            "url": "https://d8.music.126.net/dmusic2/NeteaseCloudMusic_Music_official_3.1.29.205104_64.exe#/dl.7z",
            "hash": "b246aef4c112fd6632579897a7c4a3405becc46825db0a15d97b9aa1bdc2141b"
        },
        "32bit": {
            "url": "https://d8.music.126.net/dmusic2/NeteaseCloudMusic_Music_official_3.1.29.205104_32.exe#/dl.7z",
            "hash": "13dafabb0f740b794631391dff4a69ca56fee05fbb4b8f1169e492d4c8f444e8"
        }
    },
    "installer": {
        "script": [
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "Get-ChildItem \"$dir\\redist_packages\" | Move-Item -Destination \"$dir\" -Force",
            "New-PersistDirectory \"$env:LOCALAPPDATA\\Netease\\CloudMusic\" \"$persist_dir\\AppData\" -Migrate"
        ]
    },
    "post_install": [
        "Remove-Item \"$dir\\`$PLUGINSDIR\",\"$dir\\redist_packages\" -Force -Recurse",
        "New-NetFirewallRule -DisplayName 'Block NetEase Cloud Music UDP Inbound (Scoop)' -Program \"$original_dir\\cloudmusic.exe\" -Protocol UDP -Direction Inbound -Action Block -ErrorAction SilentlyContinue",
        "New-NetFirewallRule -DisplayName 'Block NetEase Cloud Music UDP Outbound (Scoop)' -Program \"$original_dir\\cloudmusic.exe\" -Protocol UDP -Direction Outbound -Action Block -ErrorAction SilentlyContinue"
    ],
    "uninstaller": {
        "script": [
            "$bucket = $install.bucket",
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "Stop-App",
            "Remove-Junction \"$env:LOCALAPPDATA\\Netease\\CloudMusic\"",
            "Remove-NetFirewallRule -DisplayName 'Block NetEase Cloud Music UDP Inbound (Scoop)' -ErrorAction SilentlyContinue",
            "Remove-NetFirewallRule -DisplayName 'Block NetEase Cloud Music UDP Outbound (Scoop)' -ErrorAction SilentlyContinue"
        ]
    },
    "bin": "cloudmusic.exe",
    "shortcuts": [
        [
            "cloudmusic.exe",
            "网易云音乐"
        ]
    ],
    "checkver": {
        "script": [
            "Import-Module \"$pwd\\bin\\WinGet.psm1\"",
            "$Manifest = Get-WinGetInfo -Id 'NetEase.CloudMusic'",
            "$version  = $Manifest.latest_version",
            "return \"$version\""
        ],
        "regex": "(.*)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://d8.music.126.net/dmusic2/NeteaseCloudMusic_Music_official_$version_64.exe#/dl.7z"
            },
            "32bit": {
                "url": "https://d8.music.126.net/dmusic2/NeteaseCloudMusic_Music_official_$version_32.exe#/dl.7z"
            }
        }
    }
}
