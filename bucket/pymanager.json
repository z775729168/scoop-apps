{
    "version": "26.1",
    "homepage": "https://www.python.org/downloads/latest/pymanager/",
    "description": "The Python Install Manager (for Windows)",
    "license": {
        "identifier": "PSF-2.0",
        "url": "https://opensource.org/licenses/Python-2.0"
    },
    "url": "https://www.python.org/ftp/python/pymanager/python-manager-26.1.msi",
    "hash": "a7a7c9d283264bec3ac5fbb84634e2af5b8aa7eeb6d502e9d20a67551390a77d",
    "extract_dir": "PFiles64\\PyManager",
    "env_add_path": ".",
    "installer": {
        "script": [
            "if ($global) {",
            "    $registry_scope = \"HKEY_LOCAL_MACHINE\"",
            "} else {",
            "    $registry_scope = \"HKEY_CURRENT_USER\"",
            "}",
            "@\"",
            "Windows Registry Editor Version 5.00",
            "",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\.py]",
            "@=\"Python.File\"",
            "\"Content Type\"=\"text/x-python\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\.pyc]",
            "@=\"Python.CompiledFile\"",
            "\"Content Type\"=\"application/x-python-code\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\.pyd]",
            "@=\"Python.Extension\"",
            "\"Content Type\"=\"application/x-python-pyd\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\.pyw]",
            "@=\"Python.NoConFile\"",
            "\"Content Type\"=\"text/x-python\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\.pyz]",
            "@=\"Python.ArchiveFile\"",
            "\"Content Type\"=\"application/x-python-zipapp\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\.pyzw]",
            "@=\"Python.NoConArchiveFile\"",
            "\"Content Type\"=\"application/x-python-zipapp\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\CLSID\\{C7E29CB0-9691-4DE8-B72B-6719DDC0B4A1}\\InprocServer32]",
            "@=\"$($dir -replace '\\\\','\\\\')\\\\pyshellext-64.dll\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\CLSID\\{EAF5E48F-F54A-4A03-824B-CA880772EE20}\\InprocServer32]",
            "@=\"$($dir -replace '\\\\','\\\\')\\\\pyshellext-64.dll\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\Python.ArchiveFile]",
            "@=\"Python Application\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\Python.ArchiveFile\\DefaultIcon]",
            "@=\"\\\"$($dir -replace '\\\\','\\\\')\\\\python.exe\\\"\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\Python.ArchiveFile\\shell\\open\\command]",
            "@=\"\\\"$($dir -replace '\\\\','\\\\')\\\\python.exe\\\" \\\"%1\\\" %*\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\Python.CompiledFile]",
            "@=\"Compiled Python Script\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\Python.CompiledFile\\DefaultIcon]",
            "@=\"\\\"$($dir -replace '\\\\','\\\\')\\\\pyc.ico\\\"\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\Python.CompiledFile\\shell\\open\\command]",
            "@=\"\\\"$($dir -replace '\\\\','\\\\')\\\\python.exe\\\" \\\"%1\\\" %*\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\Python.Extension]",
            "@=\"Python Extension Module\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\Python.Extension\\DefaultIcon]",
            "@=\"\\\"$($dir -replace '\\\\','\\\\')\\\\pyd.ico\\\"\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\Python.File]",
            "@=\"Python Script\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\Python.File\\DefaultIcon]",
            "@=\"\\\"$($dir -replace '\\\\','\\\\')\\\\py.ico\\\"\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\Python.File\\shell\\EditWithIDLE]",
            "\"ExplorerCommandHandler\"=\"{C7E29CB0-9691-4DE8-B72B-6719DDC0B4A1}\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\Python.File\\shell\\open\\command]",
            "@=\"\\\"$($dir -replace '\\\\','\\\\')\\\\python.exe\\\" \\\"%1\\\" %*\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\Python.File\\shellex\\DropHandler]",
            "@=\"{EAF5E48F-F54A-4A03-824B-CA880772EE20}\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\Python.NoConArchiveFile]",
            "@=\"Python Application (Windowed)\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\Python.NoConArchiveFile\\DefaultIcon]",
            "@=\"\\\"$($dir -replace '\\\\','\\\\')\\\\pythonw.exe\\\"\"",
            "",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\Python.NoConArchiveFile\\shell\\open\\command]",
            "@=\"\\\"$($dir -replace '\\\\','\\\\')\\\\pythonw.exe\\\" \\\"%1\\\" %*\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\Python.NoConFile]",
            "@=\"Python Script (Windowed)\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\Python.NoConFile\\DefaultIcon]",
            "@=\"\\\"$($dir -replace '\\\\','\\\\')\\\\py.ico\\\"\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\Python.NoConFile\\shell\\EditWithIDLE]",
            "\"ExplorerCommandHandler\"=\"{C7E29CB0-9691-4DE8-B72B-6719DDC0B4A1}\"",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\Python.NoConFile\\shell\\open\\command]",
            "@=\"\\\"$($dir -replace '\\\\','\\\\')\\\\pythonw.exe\\\" \\\"%1\\\" %*\"",
            "",
            "",
            "[$registry_scope\\SOFTWARE\\Classes\\Python.NoConFile\\shellex\\DropHandler]",
            "@=\"{EAF5E48F-F54A-4A03-824B-CA880772EE20}\"",
            "",
            "\"@ | Set-Content -Path \"$dir\\install_PyManager.reg\" -Encoding Unicode",
            "",
            "reg.exe import \"$dir\\install_PyManager.reg\" *>$null"
        ]
    },
    "uninstaller": {
        "script": [
            "if ($global) {",
            "    $registry_scope = \"HKLM\"",
            "} else {",
            "    $registry_scope = \"HKCU\"",
            "}",
            "",
            "reg.exe delete \"$registry_scope\\Software\\Classes\\.py\" /f *>$null",
            "reg.exe delete \"$registry_scope\\Software\\Classes\\.pyc\" /f *>$null",
            "reg.exe delete \"$registry_scope\\Software\\Classes\\.pyd\" /f *>$null",
            "reg.exe delete \"$registry_scope\\Software\\Classes\\.pyw\" /f *>$null",
            "reg.exe delete \"$registry_scope\\Software\\Classes\\.pyz\" /f *>$null",
            "reg.exe delete \"$registry_scope\\Software\\Classes\\.pyzw\" /f *>$null",
            "reg.exe delete \"$registry_scope\\Software\\Classes\\CLSID\\{C7E29CB0-9691-4DE8-B72B-6719DDC0B4A1}\" /f *>$null",
            "reg.exe delete \"$registry_scope\\Software\\Classes\\CLSID\\{EAF5E48F-F54A-4A03-824B-CA880772EE20}\" /f *>$null",
            "reg.exe delete \"$registry_scope\\Software\\Classes\\Python.ArchiveFile\" /f *>$null",
            "reg.exe delete \"$registry_scope\\Software\\Classes\\Python.CompiledFile\" /f *>$null",
            "reg.exe delete \"$registry_scope\\Software\\Classes\\Python.Extension\" /f *>$null",
            "reg.exe delete \"$registry_scope\\Software\\Classes\\Python.File\" /f *>$null",
            "reg.exe delete \"$registry_scope\\Software\\Classes\\Python.NoConArchiveFile\" /f *>$null",
            "reg.exe delete \"$registry_scope\\Software\\Classes\\Python.NoConFile\" /f *>$null"
        ]
    },
    "checkver": {
        "url": "https://www.python.org/downloads/latest/pymanager/",
        "regex": "https://www.python.org/ftp/python/pymanager/python-manager-([\\d.]+)\\.msi"
    },
    "autoupdate": {
        "url": "https://www.python.org/ftp/python/pymanager/python-manager-$version.msi"
    }
}
