    "shortcuts": [
        [
            "BaiduNetdisk.exe",
            "百度网盘"
        ]
    ],
    "persist": "users",
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Import-AppxPSModule",
        "Get-AppxPackage -Name \"3AD8A913.49937325EFC59\" | Remove-AppxPackage",
        "Remove-NetFirewallRule -DisplayName 'Block BaiduNetdiskHost Inbound (Scoop)' -ErrorAction SilentlyContinue",
        "Remove-NetFirewallRule -DisplayName 'Block BaiduNetdiskUnite Inbound (Scoop)' -ErrorAction SilentlyContinue"
    ],
    "installer": {
        "script": [
            "Remove-Item \"$dir\\`$*\" -Recurse -Force",
            "Rename-Item \"$dir\\AutoUpdate\" -NewName \"AutoUpdate_Bak\"",
            "Rename-Item \"$dir\\sysres\" -NewName \"sysres_Bak\"",
            "Rename-Item \"$dir\\BaiduNetdiskService.Msixbundle\" -NewName \"BaiduNetdiskService.Msixbundle.Bak\""
        ]
    },
    "post_install": [
        "New-NetFirewallRule -DisplayName 'Block BaiduNetdiskHost Inbound (Scoop)' -Program \"$original_dir\\module\\BrowserEngine\\baidunetdiskhost.exe\" -Direction Inbound -Action Block -ErrorAction SilentlyContinue",
        "New-NetFirewallRule -DisplayName 'Block BaiduNetdiskUnite Inbound (Scoop)' -Program \"$original_dir\\module\\BrowserEngine\\baidunetdiskunite.exe\" -Direction Inbound -Action Block -ErrorAction SilentlyContinue"
    ],
    "uninstaller": {
        "script": [
            "Remove-Item -Path \"$env:APPDATA\\PLogs\" -Force -Recurse -ErrorAction SilentlyContinue | Out-Null",
            "Remove-Item -Path \"$env:APPDATA\\BaiduYunKernel\" -Force -Recurse -ErrorAction SilentlyContinue | Out-Null",
            "Remove-Item -Path \"$env:APPDATA\\BaiduYunGuanjia\" -Force -Recurse -ErrorAction SilentlyContinue | Out-Null",
            "Remove-Item -Path \"$env:APPDATA\\Baidu\\BaiduNetdisk\" -Force -Recurse -ErrorAction SilentlyContinue | Out-Null",
            "Remove-Item -Path \"$env:APPDATA\\Baidu\\BaiduYunKernel\" -Force -Recurse -ErrorAction SilentlyContinue | Out-Null"
        ]
    },
    "checkver": {
        "url": "https://pan.baidu.com/disk/cmsdata?do=client",
