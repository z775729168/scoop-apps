        ]
    ],
    "post_install": [
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "New-PersistDirectory \"$env:USERPROFILE\\.xmcl\" \"$persist_dir\\.xmcl\" -Migrate",
