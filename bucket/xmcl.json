    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:USERPROFILE\\.xmcl\"",
        "Remove-Junction \"$env:APPDATA\\xmcl\""
    ],
    "checkver": {
        "github": "https://github.com/Voxelum/x-minecraft-launcher"
    },
    "autoupdate": {
        "architecture": {
