            "hash": "bb87cdc9f3ea5b577eb96806fc70dcc4a0c3830b0457568538a22f491a912c1c"
        },
        "32bit": {
            "url": "https://github.com/Voxelum/x-minecraft-launcher/releases/download/v0.54.5/xmcl-0.54.5-win32-ia32.zip",
            "hash": "e4cdf0d943f4f996e7688b60a7a6b832bf786f60ef89c5ad9fc746c40d6ec224"
        }
    },
    "shortcuts": [
        [
            "X Minecraft Launcher.exe",
            "X Minecraft Launcher"
        ]
    ],
    "post_install": [
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "New-PersistDirectory \"$env:USERPROFILE\\.xmcl\" \"$persist_dir\\.xmcl\" -Migrate",
        "New-PersistDirectory \"$env:APPDATA\\xmcl\" \"$persist_dir\\xmcl\" -Migrate"
    ],
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:USERPROFILE\\.xmcl\"",
        "Remove-Junction \"$env:APPDATA\\xmcl\""
    ],
    "checkver": {
        "github": "https://github.com/Voxelum/x-minecraft-launcher"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
