{
    "version": "1.0.21.702",
    "description": "Clash Mihomo for iOS/Android",
    "homepage": "https://github.com/KaringX/clashmi",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/KaringX/clashmi/releases/download/v1.0.21.702/clashmi_1.0.21.702_windows_x64.zip",
            "hash": "7b75832cd5bc31422c8fbaf6f7c0bc94607c3e83d0d6855be680d48b7311fe5d"
        }
    },
    "bin": "clashmi.exe",
    "shortcuts": [
        [
            "clashmi.exe",
            "ClashMi"
        ]
    ],
    "persist": "portable",
    "installer": {
        "script": [
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "New-PersistDirectory \"$env:APPDATA\\clashmi\" \"$persist_dir\\AppData\" -Migrate"
        ]
    },
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:APPDATA\\clashmi\""
    ],
    "checkver": {
        "url": "https://api.github.com/repos/KaringX/clashmi/releases?per_page=1",
        "jsonpath": "$.[0].tag_name",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/KaringX/clashmi/releases/download/v$version/clashmi_$version_windows_x64.zip"
            }
        }
    }
}
