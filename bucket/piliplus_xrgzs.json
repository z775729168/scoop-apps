{
    "version": "2.0.4",
    "description": "使用Flutter开发的BiliBili第三方客户端",
    "homepage": "https://github.com/bggRGjQaUbCoE/PiliPlus",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/bggRGjQaUbCoE/PiliPlus/releases/download/2.0.4/PiliPlus_windows_2.0.4+4848_x64_portable.zip",
            "hash": "cd4c6d373733cd5d39780cfd938286f98ac662ed80bb5409546f3cc7b4f0e545"
        }
    },
    "extract_dir": "PiliPlus-Win",
    "shortcuts": [
        [
            "piliplus.exe",
            "PiliPlus"
        ]
    ],
    "installer": {
        "script": [
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "New-PersistDirectory \"$env:APPDATA\\com.example\\piliplus\" \"$persist_dir\\AppData\" -Migrate"
        ]
    },
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:APPDATA\\com.example\\piliplus\"",
        "Remove-EmptyDirectory \"$env:APPDATA\\com.example\""
    ],
    "checkver": {
        "url": "https://api.github.com/repos/bggRGjQaUbCoE/PiliPlus/releases/latest",
        "regex": "/download/([^/]+)/PiliPlus_windows_(?<main>[\\d.]+)%2B(?<build>\\d+)_x64"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/bggRGjQaUbCoE/PiliPlus/releases/download/$version/PiliPlus_windows_$matchMain+$matchBuild_x64_portable.zip"
            }
        }
    }
}
