        "reg.exe delete \"$registry_scope\\SOFTWARE\\Classes\\MailMaster\" /f",
        "reg.exe delete \"$registry_scope\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\App Paths\\mailmaster.exe\" /f",
        "reg.exe delete \"$registry_scope\\SOFTWARE\\Wow6432Node\\CLSID\\{2A535B11-6CFC-4E85-A75F-0E397B1584CF}\" /f",
        "if ($cmd -eq 'uninstall') {",
