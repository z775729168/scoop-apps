        "@=\"MailMasterShell.FileContextMenuExt Class\"",
        "[$registry_scope\\SOFTWARE\\Classes\\CLSID\\{2A535B11-6CFC-4E85-A75F-0E397B1584CF}\\InprocServer32]",
        "@=\"$instdir\\\\$version\\\\mailmaster_shell_64.dll\"",
        "\"ThreadingModel\"=\"Apartment\"",
        "[$registry_scope\\SOFTWARE\\Classes\\MailMaster]",
        "@=\"网易邮箱大师\"",
        "\"AppUserModelId\"=\"MailMaster\"",
        "\"URL Protocol\"=\"\"",
        "[$registry_scope\\SOFTWARE\\Classes\\MailMaster\\Application]",
        "\"ApplicationCompany\"=\"NetEase(Hangzhou) Network Co. Ltd.\"",
        "\"ApplicationDescription\"=\"网易邮箱大师，安全，高效，便捷\"",
        "\"ApplicationIcon\"=\"$instdir\\\\mailmaster.exe,0\"",
        "\"ApplicationName\"=\"网易邮箱大师\"",
        "\"AppUserModelId\"=\"MailMaster\"",
        "[$registry_scope\\SOFTWARE\\Classes\\MailMaster\\DefaultIcon]",
        "@=\"$instdir\\\\mailmaster.exe,0\"",
        "[$registry_scope\\SOFTWARE\\Classes\\MailMaster\\shell\\open\\command]",
        "@=\"\\\"$instdir\\\\mailmaster.exe\\\" -- \\\"%1\\\"\"",
        "[$registry_scope\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\App Paths\\mailmaster.exe]",
        "@=\"$instdir\\\\mailmaster.exe\"",
        "\"Path\"=\"$instdir\"",
        "[$registry_scope\\SOFTWARE\\Wow6432Node\\CLSID\\{2A535B11-6CFC-4E85-A75F-0E397B1584CF}]",
        "@=\"MailMasterShell.FileContextMenuExt Class\"",
