    "installer": {
        "script": [
            "Expand-7ZipArchive \"$dir\\mailmaster.7z\" \"$dir\" -Removal",
            "Move-Item \"$dir\\MailMaster-bin\\*\" \"$dir\" -Force",
            "Remove-Item \"$dir\\MailMaster-bin\" -Force -Recurse"
        ]
    },
    "post_install": [
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
