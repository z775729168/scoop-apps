        "@=\"$instdir\\\\$version\\\\mailmaster_shell_32.dll\"",
        "\"ThreadingModel\"=\"Apartment\"",
        "\"@ | Set-Content -Path \"$dir\\install-mailmaster.reg\" -Encoding Unicode",
