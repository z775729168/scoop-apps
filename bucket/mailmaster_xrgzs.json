    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:LOCALAPPDATA\\Netease\\MailMaster\"",
        "if ($global) {",
        "    $registry_scope = \"HKLM\"",
        "} else {",
        "    $registry_scope = \"HKCU\"",
        "}",
        "reg.exe delete \"$registry_scope\\SOFTWARE\\Classes\\*\\shellex\\ContextMenuHandlers\\MailMaster\" /f",
        "reg.exe delete \"$registry_scope\\SOFTWARE\\Classes\\.eml\\OpenWithProgids\" /v \"MailMaster\" /f",
