{
    "version": "3.5.0",
    "description": "MediaGo 跨平台视频提取工具：支持流媒体下载、视频下载、m3u8 下载及 B站视频下载，提供 Windows 和 Mac 桌面客户端。",
    "homepage": "https://downloader.caorushizi.cn/",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/mediago-dev/mediago/releases/download/v3.5.0/mediago-community-setup-win32-x64-3.5.0.exe#/dl.7z",
            "hash": "sha512:f968fe16293c17c0e7a3ae33b832e7d5a8761751b60f20ceb52c5c09f4c6371ea34b38ac7cc52dda0950e59fcb464f4545fb599bfd89b46e5f3f28ad33a7eaec"
        }
    },
    "shortcuts": [
        [
            "mediago.exe",
            "MediaGo"
        ]
    ],
    "installer": {
        "script": [
            "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
            "Remove-Item \"$dir\\`$*\" -Force -Recurse",
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "New-PersistDirectory \"$env:APPDATA\\MediaGo\" \"$persist_dir\\AppData\" -Migrate",
            "if (!(Test-Path \"$persist_dir\\config.json\") -or !(Get-Item \"$persist_dir\\config.json\").Length) {",
            "    New-Item \"$persist_dir\\config.json\" -ItemType File -Force -ErrorAction SilentlyContinue | Out-Null",
            "    Set-Content -Path \"$persist_dir\\config.json\" -Value '{\"autoUpgrade\": false}'",
            "}"
        ]
    },
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:APPDATA\\MediaGo\""
    ],
    "checkver": {
        "github": "https://github.com/caorushizi/mediago"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/mediago-dev/mediago/releases/download/v$version/mediago-community-setup-win32-x64-$version.exe#/dl.7z",
                "hash": {
                    "url": "$baseurl/latest.yml",
                    "regex": "(?sm)$basename.*?sha512:\\s+$base64"
                }
            }
        }
    }
}
