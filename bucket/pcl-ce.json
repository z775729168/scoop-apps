    "pre_install": [
        "# Ensure game directory is set to persist directory",
        "ensure \"$persist_dir\\PCL\"",
        "ensure \"$persist_dir\\.minecraft\"",
        "ensure \"$persist_dir\\.minecraft\\versions\"",
        "if (!(Test-Path \"$persist_dir\\PCL\\Setup.ini\") -or !(Get-Item \"$persist_dir\\PCL\\Setup.ini\").Length) {",
        "    New-Item \"$persist_dir\\PCL\\Setup.ini\" -ItemType File -Force -ErrorAction SilentlyContinue | Out-Null",
        "    Set-Content -Path \"$persist_dir\\PCL\\Setup.ini\" -Value \"LaunchFolderSelect:$persist_dir\\.minecraft\\`nSystemSystemUpdate:3\"",
        "}"
    ],
    "persist": [
        "PCL",
        ".minecraft"
