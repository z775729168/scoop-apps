    "installer": {
        "script": [
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "New-PersistDirectory \"$env:APPDATA\\Shandianshuo\" \"$persist_dir\\AppData\" -Migrate",
            "New-PersistDirectory \"$env:LOCALAPPDATA\\cn.shandianshuo.desktop\" \"$persist_dir\\LocalAppData\" -Migrate",
