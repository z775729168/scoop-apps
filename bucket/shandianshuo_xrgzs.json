        ]
    },
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:APPDATA\\Shandianshuo\"",
        "Remove-Junction \"$env:LOCALAPPDATA\\cn.shandianshuo.desktop\""
    ],
    "checkver": {
        "url": "https://update.shandianshuo.cn/windows/latest.json",
        "jsonpath": "$.version"
    },
