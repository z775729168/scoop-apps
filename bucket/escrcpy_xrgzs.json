        "Remove-Junction \"$env:APPDATA\\escrcpy\""
    ],
    "shortcuts": [
        [
            "Escrcpy.exe",
            "Escrcpy"
        ]
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
