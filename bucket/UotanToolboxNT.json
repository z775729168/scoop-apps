    "installer": {
        "script": [
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "New-PersistDirectory \"$env:LocalAppData\\UotanToolbox\" \"$persist_dir\\LocalAppData\" -Migrate"
