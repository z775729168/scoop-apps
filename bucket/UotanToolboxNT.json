            "hash": "f3f4087a0e4be4a4ffb35dfd682465ef4cef08218a74b3f5728a046592ace164"
        },
        "arm64": {
            "url": "https://github.com/Uotan-Dev/UotanToolboxNT/releases/download/3.6.1/UotanToolbox_Windows_arm64_3.6.1.zip",
