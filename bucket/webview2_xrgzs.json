    "env_set": {
        "WEBVIEW2_BROWSER_EXECUTABLE_FOLDER": "$dir"
    },
    "post_install": [
        "# Block global install without admin",
        "if ($global -and !(is_admin)) {",
        "    error 'Administrator rights are required for global install.'",
        "    scoop uninstall $app",
        "    exit 1",
        "}",
        "",
        "# Determine standard installation path",
        "if (is_admin) {",
        "    $wvBase = if (${env:ProgramFiles(x86)}) { \"${env:ProgramFiles(x86)}\\Microsoft\\EdgeWebView\\Application\" } else { \"$env:ProgramFiles\\Microsoft\\EdgeWebView\\Application\" }",
        "} else {",
        "    $wvBase = \"$env:LOCALAPPDATA\\Microsoft\\EdgeWebView\\Application\"",
        "}",
        "$wvPath = \"$wvBase\\$version\"",
        "",
        "# Uninstall existing official WebView2 if present",
        "$exe1 = \"$env:LOCALAPPDATA\\Microsoft\\EdgeUpdate\\MicrosoftEdgeUpdate.exe\"",
        "$exe2 = \"${env:ProgramFiles(x86)}\\Microsoft\\EdgeUpdate\\MicrosoftEdgeUpdate.exe\"",
        "if (Test-Path $exe1) { & $exe1 /uninstall 2>$null }",
        "if (Test-Path $exe2) { & $exe2 /uninstall 2>$null }",
        "",
        "# Kill Edge Update related processes",
        "Stop-Process -Name 'MicrosoftEdgeUpdate' -Force -ErrorAction SilentlyContinue",
        "Stop-Process -Name 'msedgewebview2' -Force -ErrorAction SilentlyContinue",
        "",
        "# Stop and remove Edge Update services",
        "'edgeupdate', 'edgeupdatem', 'MicrosoftEdgeElevationService' | ForEach-Object {",
        "    Stop-Service -Name $_ -Force -ErrorAction SilentlyContinue",
        "    sc.exe delete $_ 2>&1 | Out-Null",
        "}",
        "",
        "# Remove scheduled tasks",
        "'MicrosoftEdgeUpdateTaskUserS', 'MicrosoftEdgeUpdateTaskMachineUA', 'MicrosoftEdgeUpdateTaskMachineCore', 'MicrosoftEdgeUpdateBrowserReplacementTask' | ForEach-Object {",
        "    schtasks.exe /delete /f /tn $_ 2>&1 | Out-Null",
        "}",
        "Remove-Item -Path \"$env:windir\\System32\\Tasks\\MicrosoftEdgeUpdate*\" -Force -ErrorAction SilentlyContinue",
        "",
        "# Remove unused registry keys",
        "'Registry::HKEY_USERS\\.DEFAULT\\Software\\Microsoft\\EdgeUpdate', 'HKCU:\\SOFTWARE\\Microsoft\\EdgeUpdate', 'HKLM:\\SOFTWARE\\Microsoft\\EdgeUpdate', 'HKLM:\\SOFTWARE\\WOW6432Node\\Microsoft\\EdgeUpdate', 'HKLM:\\SYSTEM\\CurrentControlSet\\Services\\EventLog\\Application\\edgeupdate', 'HKLM:\\SYSTEM\\CurrentControlSet\\Services\\EventLog\\Application\\edgeupdatem', 'HKCU:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\Microsoft Edge Update', 'HKCU:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\Microsoft EdgeWebView' | ForEach-Object {",
        "    Remove-Item -Path $_ -Recurse -Force -ErrorAction SilentlyContinue",
        "}",
        "",
        "# Remove background components",
        "\"$env:windir\\SystemTemp\\MsEdgeCrashpad\", \"$env:LOCALAPPDATA\\Microsoft\\EdgeUpdate\", \"$env:LOCALAPPDATA\\Microsoft\\EdgeCore\", \"${env:ProgramFiles(x86)}\\Microsoft\\EdgeUpdate\", \"${env:ProgramFiles(x86)}\\Microsoft\\EdgeCore\", \"$env:ProgramData\\Microsoft\\EdgeUpdate\" | ForEach-Object {",
        "    Remove-Item -Path $_ -Recurse -Force -ErrorAction SilentlyContinue",
        "}",
        "",
        "# Set registry keys so applications can detect WebView2",
        "if (is_admin) {",
        "    $regBase = if ([Environment]::Is64BitOperatingSystem) { 'HKLM:\\SOFTWARE\\WOW6432Node\\Microsoft\\EdgeUpdate' } else { 'HKLM:\\SOFTWARE\\Microsoft\\EdgeUpdate' }",
        "    New-Item -Path \"$regBase\\ClientState\\{F3017226-FE2A-4295-8BDF-00C3A9A7E4C5}\" -Force -ErrorAction SilentlyContinue | Out-Null",
        "    Set-ItemProperty -Path \"$regBase\\ClientState\\{F3017226-FE2A-4295-8BDF-00C3A9A7E4C5}\" -Name 'EBWebView' -Value $wvPath -Force",
        "    New-Item -Path \"$regBase\\ClientState\\{F3017226-FE2A-4295-8BDF-00C3A9AEB816}\" -Force -ErrorAction SilentlyContinue | Out-Null",
        "    Set-ItemProperty -Path \"$regBase\\ClientState\\{F3017226-FE2A-4295-8BDF-00C3A9AEB816}\" -Name 'pv' -Value '$version' -Force",
        "}",
        "New-Item -Path 'HKCU:\\SOFTWARE\\Microsoft\\EdgeUpdate\\ClientState\\{F3017226-FE2A-4295-8BDF-00C3A9A7E4C5}' -Force -ErrorAction SilentlyContinue | Out-Null",
        "Set-ItemProperty -Path 'HKCU:\\SOFTWARE\\Microsoft\\EdgeUpdate\\ClientState\\{F3017226-FE2A-4295-8BDF-00C3A9A7E4C5}' -Name 'EBWebView' -Value $wvPath -Force",
        "New-Item -Path 'HKCU:\\SOFTWARE\\Microsoft\\EdgeUpdate\\ClientState\\{F3017226-FE2A-4295-8BDF-00C3A9AEB816}' -Force -ErrorAction SilentlyContinue | Out-Null",
        "Set-ItemProperty -Path 'HKCU:\\SOFTWARE\\Microsoft\\EdgeUpdate\\ClientState\\{F3017226-FE2A-4295-8BDF-00C3A9AEB816}' -Name 'pv' -Value '$version' -Force",
        "",
        "# Create junction link at standard installation path",
        "if (Test-Path $wvPath) { Remove-Item -Path $wvPath -Recurse -Force }",
        "New-Item -Path $wvBase -ItemType Directory -Force | Out-Null",
        "New-Item -Path $wvPath -ItemType Junction -Value $dir -Force | Out-Null",
        "",
        "# Prevent Edge from reinstalling",
        "if (is_admin) {",
        "    New-Item -Path $regBase -Force -ErrorAction SilentlyContinue | Out-Null",
        "    Set-ItemProperty -Path $regBase -Name 'DoNotUpdateToEdgeWithChromium' -Value 1 -Type DWord -Force",
        "}"
    ],
    "pre_uninstall": [
        "# Admin install requires admin to uninstall",
        "if (!(is_admin) -and (Test-Path \"${env:ProgramFiles(x86)}\\Microsoft\\EdgeWebView\\Application\\$version\")) {",
        "    error 'Administrator rights are required to uninstall $app.'",
        "    exit 1",
        "}",
        "",
        "# Determine standard installation path",
        "if (is_admin) {",
        "    $wvBase = if (${env:ProgramFiles(x86)}) { \"${env:ProgramFiles(x86)}\\Microsoft\\EdgeWebView\\Application\" } else { \"$env:ProgramFiles\\Microsoft\\EdgeWebView\\Application\" }",
        "} else {",
        "    $wvBase = \"$env:LOCALAPPDATA\\Microsoft\\EdgeWebView\\Application\"",
        "}",
        "$wvPath = \"$wvBase\\$version\"",
        "[System.IO.Directory]::Delete($wvPath, $false) 2>$null",
        "",
        "# Remove registry detection keys",
        "if (is_admin) {",
        "    $regBase = if ([Environment]::Is64BitOperatingSystem) { 'HKLM:\\SOFTWARE\\WOW6432Node\\Microsoft\\EdgeUpdate' } else { 'HKLM:\\SOFTWARE\\Microsoft\\EdgeUpdate' }",
        "    Remove-ItemProperty -Path \"$regBase\\ClientState\\{F3017226-FE2A-4295-8BDF-00C3A9A7E4C5}\" -Name 'EBWebView' -Force -ErrorAction SilentlyContinue",
        "    Remove-ItemProperty -Path \"$regBase\\ClientState\\{F3017226-FE2A-4295-8BDF-00C3A9AEB816}\" -Name 'pv' -Force -ErrorAction SilentlyContinue",
        "} else {",
        "    Remove-ItemProperty -Path 'HKCU:\\SOFTWARE\\Microsoft\\EdgeUpdate\\ClientState\\{F3017226-FE2A-4295-8BDF-00C3A9A7E4C5}' -Name 'EBWebView' -Force -ErrorAction SilentlyContinue",
        "    Remove-ItemProperty -Path 'HKCU:\\SOFTWARE\\Microsoft\\EdgeUpdate\\ClientState\\{F3017226-FE2A-4295-8BDF-00C3A9AEB816}' -Name 'pv' -Force -ErrorAction SilentlyContinue",
        "}"
    ],
