{
    "version": "0.8.93",
    "description": "基于ClashMeta的多平台代理客户端，简单易用，开源无广告。",
    "homepage": "https://github.com/chen08209/FlClash",
    "license": "GPL-3.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://github.com/chen08209/FlClash/releases/download/v0.8.93/FlClash-0.8.93-windows-amd64.zip",
            "hash": "8381c9db07c568519e7554bb224afebd98766c5ffeb13dd1f1b9e6eca72f100a"
        }
    },
    "shortcuts": [
        [
            "FlClash.exe",
            "FlClash"
        ]
    ],
    "installer": {
        "script": [
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "# Migrate old manifest's persist if exists",
            "if (Test-Path \"$persist_dir\\AppData\\clash\") {",
            "    Move-Item \"$persist_dir\\AppData\\clash\\*\" \"$persist_dir\\AppData\" -Force",
            "    Remove-EmptyDirectory \"$persist_dir\\AppData\\clash\"",
            "}",
            "New-PersistDirectory \"$env:APPDATA\\com.follow\\clash\" \"$persist_dir\\AppData\" -Migrate"
        ]
    },
    "pre_uninstall": [
        "while (Get-Service -Name 'FlClashHelperService' -ErrorAction SilentlyContinue) {",
        "    Invoke-ExternalCommand 'sc.exe' -ArgumentList @('stop', 'FlClashHelperService') -RunAs -Quiet",
        "    Invoke-ExternalCommand 'sc.exe' -ArgumentList @('delete', 'FlClashHelperService') -RunAs -Quiet",
        "}",
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:APPDATA\\com.follow\\clash\"",
        "Remove-EmptyDirectory \"$env:APPDATA\\com.follow\""
    ],
    "checkver": {
        "github": "https://github.com/chen08209/FlClash"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/chen08209/FlClash/releases/download/v$version/FlClash-$version-windows-amd64.zip"
            }
        }
    }
}
