{
    "version": "5.10.40",
    "description": "NyameBox (The Original NekoBox Rebranded) - Qt based Desktop cross-platform GUI proxy utility, empowered by sing-box.",
    "homepage": "https://github.com/qr243vbi/nekobox",
    "license": "GPL-3.0-only",
    "notes": [
        "FAQ & Tips:",
        "- If you force quit NyameBox while 'System proxy' is enabled, your internet might stop working. Open it again and toggle 'System proxy' to fix it.",
        "- TUN mode will automatically request UAC (Administrator privileges) to restart nekobox_core.",
        "- Sing-Box command line mode is available via: nekobox_core sing-box --help"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/qr243vbi/nekobox/releases/download/5.10.40/nekobox-5.10.40-windows64.zip",
            "hash": "730f47a48fb58a81dcd12e74635ee0478f6d4fd0cb2943391135b44de6cecd4e"
        },
        "arm64": {
            "url": "https://github.com/qr243vbi/nekobox/releases/download/5.10.40/nekobox-5.10.40-windows-arm64.zip",
            "hash": "5323c255d659fbae616fe7a318250894dd53bf9256b6ceb734aaeee9776d95a8"
        }
    },
    "extract_dir": "nekobox",
    "persist": "settings",
    "bin": [
        "nekobox.exe",
        "nekobox_core.exe"
    ],
    "shortcuts": [
        [
            "nekobox.exe",
            "NyameBox"
        ]
    ],
    "uninstaller": {
        "script": [
            "$bucket = $install.bucket",
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "if ($cmd -eq 'uninstall') {",
            "    Remove-Item \"$env:APPDATA\\nekobox\" -Recurse -Force -ErrorAction SilentlyContinue | Out-Null",
            "    Remove-Item \"$env:LOCALAPPDATA\\nekobox\" -Recurse -Force -ErrorAction SilentlyContinue | Out-Null",
            "}"
        ]
    },
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/qr243vbi/nekobox/releases/download/$version/nekobox-$version-windows64.zip"
            },
            "arm64": {
                "url": "https://github.com/qr243vbi/nekobox/releases/download/$version/nekobox-$version-windows-arm64.zip"
            }
        }
    }
}
