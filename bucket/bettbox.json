{
    "version": "1.17.10",
    "description": "Another Better Mihomo Client",
    "homepage": "https://github.com/appshubcc/Bettbox",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/appshubcc/Bettbox/releases/download/v1.17.10/Bettbox-1.17.10-windows-amd64-setup.exe",
            "hash": "13eabea839b8b8d24f8922e1fed677837164d13cff07fafc257445c953834331"
        },
        "arm64": {
            "url": "https://github.com/appshubcc/Bettbox/releases/download/v1.17.10/Bettbox-1.17.10-windows-arm64-setup.exe",
            "hash": "5216c114710283e3d44ff5c07d0ecc6b0833b9a639dff311cb5458cc9c726e52"
        }
    },
    "innosetup": true,
    "shortcuts": [
        [
            "Bettbox.exe",
            "Bettbox"
        ]
    ],
    "installer": {
        "script": [
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "New-PersistDirectory \"$env:APPDATA\\com.appshub\\Bettbox\" \"$persist_dir\\AppData\" -Migrate"
        ]
    },
    "pre_uninstall": [
        "while (Get-Service -Name 'BetboxHelperevice' -ErrorAction SilentlyContinue) {",
        "    Invoke-ExternalCommand 'sc.exe' -ArgumentList @('stop', 'BetboxHelperevice') -RunAs -Quiet",
        "    Invoke-ExternalCommand 'sc.exe' -ArgumentList @('delete', 'BetboxHelperevice') -RunAs -Quiet",
        "}",
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:APPDATA\\com.appshub\\Bettbox\"",
        "Remove-EmptyDirectory \"$env:APPDATA\\com.appshub\""
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/appshubcc/Bettbox/releases/download/v$version/Bettbox-$version-windows-amd64-setup.exe"
            },
            "arm64": {
                "url": "https://github.com/appshubcc/Bettbox/releases/download/v$version/Bettbox-$version-windows-arm64-setup.exe"
            }
        }
    }
}
