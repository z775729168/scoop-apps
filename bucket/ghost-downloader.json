        },
        "arm64": {
            "url": "https://github.com/XiaoYouChR/Ghost-Downloader-3/releases/download/v3.8/Ghost-Downloader-v3.8-Windows-arm64.zip",
            "hash": "ba6e47c8d58cfd3557f4a03ed56022057be9f8cd0b4f1869395d407626446f34"
