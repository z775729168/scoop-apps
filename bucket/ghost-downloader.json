            "hash": "cbff1e9db45c166ce18822a8309b423dcad09053f39b138e42a47c8c73381037"
        },
        "arm64": {
            "url": "https://github.com/XiaoYouChR/Ghost-Downloader-3/releases/download/v3.7.4/Ghost-Downloader-v3.7.4-Windows-arm64.zip",
            "hash": "acd379a761fd697dfbef36ecc5ecb94f65ac37f157e49ccd7600aa8434af90e5"
