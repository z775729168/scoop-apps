            "hash": "40e4b8c6044b866806dd625b4cd7b4eec9287ea4d670e2b0bdcc2d52a9122aea"
        },
        "arm64": {
            "url": "https://github.com/XiaoYouChR/Ghost-Downloader-3/releases/download/v3.8.2/Ghost-Downloader-v3.8.2-Windows-arm64.zip",
            "hash": "98710d7bf29c362df96247444b2cbeb7766424b3932d380cdd1fd315e1f08eed"
