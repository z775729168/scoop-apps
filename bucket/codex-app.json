        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Import-AppxPSModule",
        "if ($cmd -eq 'uninstall') {",
        "    Get-AppxPackage -Name \"OpenAI.Codex\" | Remove-AppxPackage",
        "} else {",
        "    Get-AppxPackage -Name \"OpenAI.Codex\" | Remove-AppxPackage -PreserveApplicationData",
        "}"
